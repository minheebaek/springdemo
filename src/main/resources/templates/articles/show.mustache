{{>layouts/header}}
<table class="table">
    <thead>
    <tr>
        <th scope="col">ID</th>
        <th scope="col">Title</th>
        <th scope="col">Content</th>
    </tr>
    </thead>
    <tbody>
    {{#article}}
    <!--entity 가져옴, 모델에 있는 데이터는 #을 통해 갖고 올 수 있다--->
    <tr>
        <td>{{id}}</td>
        <td>{{title}}</td>
        <td>{{content}}</td>
    </tr>
   {{/article}}  <!--article을 어디까지 가져와서 쓸거냐를 설정해야함 -->
    </tbody>
</table>

<a href="/articles/{{article.id}}/edit" class="btn btn-primary">Edit</a> <!--model에 등록된 article데이터의 id를 가져올 수 있다_-->

<a href="/articles/{{article.id}}/delete" class="btn btn-danger">Delete</a> <a href="/articles">Go to Article</a> <!--href 주소로 delete요청을 보내겠다.-->

{{>layouts/footer}}